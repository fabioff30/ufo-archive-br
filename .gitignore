# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# playwright mcp test runs
.playwright-mcp/

# generated search/listing index (built from public/search-index.json)
/public/idx/*
# ... except the translation artifact — needed at deploy time and expensive
# to regenerate. Output of `npm run translate`.
!/public/idx/translations.json

# translation cache (populated by `npm run translate`)
/scripts/.cache/

# typescript
*.tsbuildinfo
next-env.d.ts
